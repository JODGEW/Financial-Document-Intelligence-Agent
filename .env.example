# Copy this file to .env and fill in values. Do not commit .env.

# --- AWS Bedrock ---
AWS_REGION=us-east-1
CHAT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# AWS credentials are resolved by boto3 from the standard chain
# (~/.aws/credentials, an IAM role, or the variables below).
# Uncomment to set them explicitly via the environment instead.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# --- Vector store (Chroma) ---
CHROMA_COLLECTION=documents

# --- Web search (optional) ---
# Needed only for the Tavily external-web fallback.
# TAVILY_API_KEY=your-tavily-api-key-here

# --- Bedrock Guardrails (optional) ---
# Set both to attach the guardrail to every model invocation.
# Provision once with scripts/setup_guardrail.py, then paste the values here.
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=
BEDROCK_GUARDRAIL_TRACE=ENABLED

# --- Audit logging (optional) ---
# Defaults to audit_logs/query_audit.jsonl when unset.
# AUDIT_LOG_PATH=audit_logs/query_audit.jsonl

# --- Document ingestion ---
# Two-tier PII redaction dispatch:
#   PII_REDACT_AT_INGEST          global, redacts every format (default off)
#   PII_REDACT_TABULAR_AT_INGEST  redacts CSV / XLSX only (default on)
PII_REDACT_AT_INGEST=false
PII_REDACT_TABULAR_AT_INGEST=true
INGEST_TABLE_EXTRACTION=true
